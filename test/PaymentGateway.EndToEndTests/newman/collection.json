  "item": [
    {
      "name": "TestHealthcheck",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Http Status code is 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Payment Gateway API is Healthy\", function() {",
              "    pm.expect(pm.response.text()).to.eql(\"Healthy\")",
              "});"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{PaymentGatewayAPIURL}}/health",
          "host": [
            "{{PaymentGatewayAPIURL}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "DeclinedPayment",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//example: https://learning.postman.com/docs/tests-and-scripts/write-scripts/test-examples",
              "pm.test(\"Http Status code is 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"For cardnumbers ending with an even number Then payment is declined\", function() {",
              "    const responseJson = pm.response.json();",
              "",
              "    pm.expect(responseJson.status).to.eql(\"Declined\");",
              "    pm.expect(responseJson.lastFourDigits).to.eql(\"4242\")",
              "});"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"CardNumber\": \"4242424242424242\",\n    \"Cvv\": \"123\",\n    \"ExpiryMonth\": 12,\n    \"ExpiryYear\": 2030,\n    \"Amount\": 5000,\n    \"Currency\": \"USD\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{PaymentGatewayAPIURL}}/api/paymentgateway/processpayment",
          "host": [
            "{{PaymentGatewayAPIURL}}"
          ],
          "path": [
            "api",
            "paymentgateway",
            "processpayment"
          ]
        }
      },
      "response": []
    },
